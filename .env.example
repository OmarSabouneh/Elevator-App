# Server
PORT=3001
JWT_SECRET=change-this-to-a-long-random-string
CLIENT_URL=http://localhost:5173
# Production: exact Vercel URL (no trailing slash), must match on Render
# CORS_ORIGINS=https://your-app.vercel.app
# ALLOW_VERCEL_PREVIEWS=true

# Database — leave unset for local SQLite; set for Supabase PostgreSQL
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# DATABASE_SSL=true

# Subscription after payment
SUBSCRIPTION_DAYS=30
SUBSCRIPTION_AMOUNT=25
SUBSCRIPTION_CURRENCY=USD

# Whish Money (codnloc gateway) — register at https://pay.codnloc.com
WHISH_WEBSITE=your-building-domain.com
WHISH_SECRET=your_whish_secret_token
# Set to "mock" to skip real API during development
WHISH_MODE=mock

# Payment webhook secret (you configure this URL in your Whish/codnloc dashboard)
PAYMENT_WEBHOOK_SECRET=change-this-webhook-secret

# Breaker / switch — mock | http | shelly | tuya
SWITCH_TYPE=mock
ELEVATOR_PULSE_MS=60000

# --- Tuya IoT Cloud (remote breaker — no local server in building) ---
# SWITCH_TYPE=tuya
# TUYA_ACCESS_ID=your_access_id
# TUYA_ACCESS_SECRET=your_access_secret
# TUYA_REGION=eu
# TUYA_DEVICE_ID=your_breaker_device_id
# TUYA_DP_CODE=switch
# (run npm run tuya:info — use exact "code" from output, often "switch" not "switch_1")
# TUYA_ON_VALUE=true
# TUYA_OFF_VALUE=false

# --- Shelly (local WiFi) ---
# SHELLY_HOST=http://192.168.1.101
# SHELLY_RELAY_ID=0

# --- Generic HTTP relay ---
# SWITCH_ON_URL=http://192.168.1.100/relay/0?turn=on
# SWITCH_OFF_URL=http://192.168.1.100/relay/0?turn=off

# Bootstrap admin (E.164 or local format, must match registration)
ADMIN_PHONE=+96170123456
ADMIN_PASSWORD=change-me
ADMIN_USERNAME=admin
