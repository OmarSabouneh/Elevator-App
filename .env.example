# Server
PORT=3001
JWT_SECRET=change-this-to-a-long-random-string
CLIENT_URL=http://localhost:5173

# Subscription length when admin activates (days)
SUBSCRIPTION_DAYS=31

# Database — leave unset for local SQLite; set for Supabase PostgreSQL
# DATABASE_URL=postgresql://postgres.[ref]:PASSWORD@....pooler.supabase.com:6543/postgres
# DATABASE_SSL=true

# Breaker / switch — mock | http | shelly | tuya
SWITCH_TYPE=mock
ELEVATOR_PULSE_MS=60000

# Tuya (production)
# TUYA_ACCESS_ID=
# TUYA_ACCESS_SECRET=
# TUYA_REGION=eu
# TUYA_DEVICE_ID=
# TUYA_DP_CODE=switch

# Bootstrap admin — sign in with phone + password
ADMIN_PHONE=+96181464733
ADMIN_PASSWORD=change-me
